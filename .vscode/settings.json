{
    "files.exclude": {
        "**/.git": true,
        "**/.gitignore": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/CVS": true,
        "**/.DS_Store": true,
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/*.pyo": true,
        "**/*.pyd": true,
        "**/venv": true,
        "**/ENV": true,
        "**/env": true,
        "**/env.bak": true,
        "**/venv.bak": true,
        "**/.pytest_cache": true,
        "**/.mypy_cache": true,
        "**/*.egg-info": true,
        "**/dist": true,
        "**/build": true,
        "**/.gitattributes": true,
        "**/.gitmodules": true,
        "**/cascade.yaml": true,
        "**/*.yaml": true,
        "**/*.yml": true,
        // Documentation and preview files

        "**/categories_preview.html": true,
        "**/transactions_preview.html": true,
        "**/ui_preview.html": true,
        // Rarely used folders
        "**/instance": true,
        "**/templates/categories/**": true,

        "**/data": true,
        // Rarely used scripts
        "**/db_check.py": true,
        "**/verify_db.py": true
    },
    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/node_modules/**": true,
        "**/.hg/**": true,
        "**/.svn/**": true
    }
}
